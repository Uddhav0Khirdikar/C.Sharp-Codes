using System;

class Program
{
    static void Main()
    {
        string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
        Random random = new Random();
        string password = "";

        for (int i = 0; i < 8; i++)
        {
            int index = random.Next(chars.Length);
            password += chars[index];
        }

        Console.WriteLine("Generated Password: " + password);
    }
}
